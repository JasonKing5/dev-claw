# === IM Gateway ===
# Telegram Bot Token (from @BotFather)
TG_BOT_TOKEN=
# Optional: HTTP proxy for Telegram API (mainland China users)
# TG_PROXY_URL=http://127.0.0.1:7890

# Feishu / Lark App credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# === Auth ===
# Comma-separated list of allowed user IDs (Telegram numeric IDs and/or Feishu open_ids)
ALLOWED_USERS=

# === AI ===
# Provider SDK format: "anthropic" (direct Anthropic API) or "openai" (LiteLLM, OpenRouter, etc.)
AI_PROVIDER=anthropic
# API Key (works for both Anthropic and OpenAI-compatible providers)
ANTHROPIC_API_KEY=
# Optional: API base URL for third-party proxies (e.g. http://localhost:4000/v1 for LiteLLM)
# ANTHROPIC_BASE_URL=
# Default model for daily use
CLAUDE_MODEL=claude-sonnet-4-5-20250514
# Deep reasoning model (triggered by /opus command)
CLAUDE_DEEP_MODEL=claude-opus-4-6-20250925

# === Database ===
# Path to SQLite database file
DB_PATH=.devclaw/memory.db
# Sliding window size (number of recent messages to include in context)
CONTEXT_WINDOW=10
